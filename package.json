{
  "name": "spinx",
  "version": "1.0.0",
  "private": true,
  "description": "SpinX mobile booking application monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:mobile",
    "dev:api": "npm run dev -w @spinx/api",
    "dev:mobile": "npm run start -w @spinx/mobile",
    "build": "npm run build -w @spinx/shared && npm run build -w @spinx/api",
    "typecheck": "npm run typecheck -w @spinx/shared && npm run typecheck -w @spinx/api && npm run typecheck -w @spinx/mobile",
    "lint": "npm run lint -w @spinx/api && npm run lint -w @spinx/mobile",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "expo-print": "~56.0.4"
  }
}
